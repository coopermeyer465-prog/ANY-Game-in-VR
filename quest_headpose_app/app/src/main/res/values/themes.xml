<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.QuestHeadpose" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/quest_accent</item>
        <item name="colorOnPrimary">@android:color/black</item>
        <item name="android:statusBarColor">@color/quest_bg</item>
        <item name="android:navigationBarColor">@color/quest_bg</item>
        <item name="android:windowBackground">@color/quest_bg</item>
        <item name="android:textColorPrimary">@color/quest_fg</item>
        <item name="android:textColorSecondary">#B4C1CC</item>
        <item name="colorSurface">@color/quest_bg</item>
        <item name="colorOnSurface">@color/quest_fg</item>
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
    </style>

    <style name="Theme.QuestHeadpose.Immersive" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="colorSurface">@android:color/black</item>
        <item name="colorOnSurface">@android:color/black</item>
    </style>
</resources>
